APP_NAME="ISP Auxiliar"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://seu-servidor/isp_auxiliar/public
APP_PROVIDER_KEY=ievo
APP_TIMEZONE=America/Sao_Paulo

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=isp_auxiliar
DB_USERNAME=isp_auxiliar
DB_PASSWORD=troque_esta_senha
DB_CHARSET=utf8mb4

MKAUTH_BASE_URL=https://ip-ou-dominio-do-mkauth
MKAUTH_API_TOKEN=
MKAUTH_CLIENT_ID=Client_Id_informado_no_mkauth
MKAUTH_CLIENT_SECRET=Client_Secret_informado_no_mkauth
MKAUTH_DB_HOST=ip-ou-dominio-do-mysql-mkauth
MKAUTH_DB_PORT=3306
MKAUTH_DB_NAME=mkradius
MKAUTH_DB_USER=isp_auxiliar
MKAUTH_DB_PASSWORD=troque_esta_senha
MKAUTH_DB_CHARSET=utf8mb4
MKAUTH_DB_HASH_ALGOS=sha256,sha1

LOG_CHANNEL=file
LOG_LEVEL=info
LOG_PATH=logs/app.log

SESSION_PATH=storage/sessions
UPLOAD_PATH=storage/uploads
TMP_PATH=tmp
